{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "AN5 Schema",
  "patterns": [
    {
      "name": "comment.line.description.an5",
      "match": "@@?description\\s*\\(\\s*\"([^\"\\\\]|\\\\.)*\"\\s*\\)"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#strings"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.an5",
          "match": "//.*$"
        },
        {
          "name": "comment.block.an5",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.an5",
          "match": "\\b(model|datasource|generator|enum|type)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.an5",
          "match": "(?i)\\b(String|Int|Integer|Boolean|Float|Double|DateTime|Date|Time|BigInt|Bytes|Decimal|Numeric|Money|SmallMoney|Byte|Short|Long|Vector|Json|Guid|UUID|Char|Varchar|NChar|NVarChar|VarBinary|Binary|Text|NText|Image|DateTime2|DateTimeOffset|SmallDateTime|Timestamp|UniqueIdentifier|Xml|Sql_Variant|SqlVariant|RowVersion|HierarchyId|Geography|Geometry|SysName|Bit|TinyInt|SmallInt|Real|Variant)\\b"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.an5",
          "match": "@@?\\w+(\\.\\w+)?"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.an5",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.an5",
          "match": "\\\\."
        }
      ]
    }
  },
  "scopeName": "source.an5-schema"
}
